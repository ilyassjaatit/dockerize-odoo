<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_project_github" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.project.github</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='integration']//div[@id='recaptcha']" position="after">
                <div class="o_setting_box o_searchable_setting col-12 col-lg-6" id="github_access">
                    <div class="o_setting_right_pane">
                        <span class="o_form_label" for="github_access_key">Github default access token</span>
                        <div class="row">
                            <field name="github_access_key"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
